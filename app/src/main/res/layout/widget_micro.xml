<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@android:id/background"
    android:background="@drawable/widget_bg_dark_88"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="10dp"
    android:paddingEnd="7dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="22dp">
        <TextView
            android:textSize="11sp"
            android:textColor="#ffffffff"
            android:id="@+id/widget_title"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_title"
            android:layout_weight="1"
            android:fontFamily="sec"
            android:letterSpacing="0.11"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#afffffff"
            android:id="@+id/plan_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_plan"
            android:layout_marginEnd="3dp"/>
        <ImageView
            android:id="@+id/refresh_button"
            android:padding="4dp"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="@string/refresh"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:baselineAligned="false"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/primary_section"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="11sp"
                android:textColor="#bfffffff"
                android:id="@+id/primary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_sample_five_hour_short"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#ffffffff"
                android:id="@+id/primary_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_sample_primary_percent_short"
                android:fontFamily="sec"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:id="@+id/secondary_section"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="11sp"
                android:textColor="#bfffffff"
                android:id="@+id/secondary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_sample_week_short"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#ffffffff"
                android:id="@+id/secondary_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_sample_secondary_percent_short"
                android:fontFamily="sec"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:id="@+id/primary_reset"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
    <TextView
        android:id="@+id/secondary_reset"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
    <LinearLayout
        android:id="@+id/reset_credit_row"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp">
        <TextView
            android:id="@+id/reset_credit_info"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
        <TextView
            android:id="@+id/reset_credit_button"
            android:layout_width="0dp"
            android:layout_height="0dp"/>
    </LinearLayout>
    <TextView
        android:id="@+id/updated_label"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
</LinearLayout>
