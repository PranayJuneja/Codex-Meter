<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lock_graphic_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/lock_graphic_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/lock_preview_dials_wide"
        android:scaleType="fitCenter"
        android:contentDescription="@string/lock_widget_graphic_preview_description"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/lock_graphic_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/lock_graphic_primary_group"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:id="@+id/lock_graphic_primary_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="36"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"
                android:textFontWeight="700"/>
            <TextView
                android:textSize="7.5sp"
                android:textColor="#c8ffffff"
                android:id="@+id/lock_graphic_primary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5H"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"/>
            <Chronometer
                android:textSize="6.5sp"
                android:textColor="#c8ffffff"
                android:id="@+id/lock_primary_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/lock_graphic_secondary_group"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:id="@+id/lock_graphic_secondary_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="68"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"
                android:textFontWeight="700"/>
            <TextView
                android:textSize="7.5sp"
                android:textColor="#c8ffffff"
                android:id="@+id/lock_graphic_secondary_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="W"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"/>
            <Chronometer
                android:textSize="6.5sp"
                android:textColor="#c8ffffff"
                android:id="@+id/lock_secondary_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
