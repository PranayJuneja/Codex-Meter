<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@android:id/background"
    android:background="@drawable/widget_bg_dark_88"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="14dp"
    android:paddingEnd="10dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="11sp"
            android:textColor="#ffffffff"
            android:id="@+id/widget_title"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_title"
            android:layout_weight="1"
            android:fontFamily="sec"
            android:letterSpacing="0.12"/>
        <TextView
            android:textSize="11sp"
            android:textColor="#afffffff"
            android:id="@+id/plan_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_plan"
            android:layout_marginEnd="5dp"/>
        <ImageView
            android:id="@+id/refresh_button"
            android:padding="5dp"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="@string/refresh"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/primary_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp">
        <TextView
            android:textSize="11sp"
            android:textColor="#d9ffffff"
            android:id="@+id/primary_label"
            android:layout_width="45dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_five_hour_short"/>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="7dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:id="@+id/primary_track"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/progress_track"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>
            <ImageView
                android:id="@+id/primary_progress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/progress_mint"
                android:scaleType="fitXY"
                android:contentDescription="@null"
                android:level="7300"/>
        </FrameLayout>
        <TextView
            android:textSize="15sp"
            android:textColor="#ffffffff"
            android:gravity="end"
            android:id="@+id/primary_percent"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_primary_percent_short"
            android:fontFamily="sec"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/secondary_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp">
        <TextView
            android:textSize="11sp"
            android:textColor="#d9ffffff"
            android:id="@+id/secondary_label"
            android:layout_width="45dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_week_short"/>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="7dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:id="@+id/secondary_track"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/progress_track"
                android:scaleType="fitXY"
                android:contentDescription="@null"/>
            <ImageView
                android:id="@+id/secondary_progress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/progress_mint"
                android:scaleType="fitXY"
                android:contentDescription="@null"
                android:level="4400"/>
        </FrameLayout>
        <TextView
            android:textSize="15sp"
            android:textColor="#ffffffff"
            android:gravity="end"
            android:id="@+id/secondary_percent"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:text="@string/widget_sample_secondary_percent_short"
            android:fontFamily="sec"/>
    </LinearLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="#8fffffff"
        android:ellipsize="end"
        android:id="@+id/primary_reset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/widget_sample_compact_reset"
        android:maxLines="1"/>
    <TextView
        android:id="@+id/secondary_reset"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/reset_credit_row"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp">
        <TextView
            android:textSize="10sp"
            android:textColor="#9fffffff"
            android:ellipsize="end"
            android:id="@+id/reset_credit_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2 resets · next expires in 3d"
            android:maxLines="1"
            android:layout_weight="1"/>
        <TextView
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffffff"
            android:gravity="center"
            android:id="@+id/reset_credit_button"
            android:background="@drawable/widget_action_dark"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:minWidth="68dp"
            android:text="Use reset"
            android:fontFamily="sec"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
    <TextView
        android:textSize="11sp"
        android:textColor="#66ffffff"
        android:ellipsize="end"
        android:id="@+id/updated_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="@string/widget_sample_updated"
        android:maxLines="1"/>
</LinearLayout>
