<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:id="@+id/lock_graphic_root"
    android:paddingTop="2dp"
    android:paddingBottom="2dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/lock_bar_primary_group"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="7.5sp"
                android:textColor="#c8ffffff"
                android:id="@+id/lock_bar_primary_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="5H"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_weight="1"
                android:fontFamily="sec"/>
            <TextView
                android:textSize="10.5sp"
                android:textColor="@android:color/white"
                android:id="@+id/lock_bar_primary_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="36"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"
                android:textFontWeight="700"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/lock_bar_primary_progress"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="36"
            android:indeterminate="false"
            android:progressDrawable="@drawable/lock_progress_monotone"
            style="?android:attr/progressBarStyleHorizontal"/>
        <Chronometer
            android:textSize="6sp"
            android:textColor="#c8ffffff"
            android:layout_gravity="end"
            android:id="@+id/lock_primary_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:fontFamily="sec"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/lock_bar_secondary_group"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="7.5sp"
                android:textColor="#c8ffffff"
                android:id="@+id/lock_bar_secondary_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="W"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:layout_weight="1"
                android:fontFamily="sec"/>
            <TextView
                android:textSize="10.5sp"
                android:textColor="@android:color/white"
                android:id="@+id/lock_bar_secondary_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="68"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:fontFamily="sec"
                android:textFontWeight="700"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/lock_bar_secondary_progress"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="68"
            android:indeterminate="false"
            android:progressDrawable="@drawable/lock_progress_monotone"
            style="?android:attr/progressBarStyleHorizontal"/>
        <Chronometer
            android:textSize="6sp"
            android:textColor="#c8ffffff"
            android:layout_gravity="end"
            android:id="@+id/lock_secondary_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:fontFamily="sec"/>
    </LinearLayout>
</LinearLayout>
